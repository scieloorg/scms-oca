msgstr ""
"Este enlace de confirmación de correo electrónico ha expirado o no es "
"válido. Por favor, <a href=\"%(email_url)s\">solicite una nueva confirmación "
"de correo electrónico</a>."

msgid "Sign In"
msgstr "Entrar"

msgid "Please sign in with one of your existing third party accounts:"
msgstr ""
"Por favor, inicie sesión con una de sus cuentas de terceros existentes:"

#, python-format
msgid ""
"Or, <a href=\"%(signup_url)s\">sign up</a> for a %(site_name)s account and "
"sign in below:"
msgstr ""
"O, <a href=\"%(signup_url)s\">regístrese</a> para una cuenta %(site_name)s e "
"inicie sesión a continuación:"

