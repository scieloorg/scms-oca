msgid ""
"If you have not created an account yet, then please <a href=\"%(signup_url)s"
"\">sign up</a> first."
msgstr ""
"Si aún no ha creado una cuenta, por favor <a href=\"%(signup_url)s"
"\">regístrese</a> primero."

msgid "Forgot Password?"
msgstr "¿Olvidó la contraseña?"

